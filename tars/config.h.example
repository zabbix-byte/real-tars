#pragma once

// =============================================================
// TARS - Configuration template
// Copy this file to "config.h" (same folder) and fill in your creds.
// NEVER commit config.h with real keys.
// =============================================================

// ---------- WiFi (solo 2.4 GHz) ----------
#define WIFI_SSID        "YOUR_WIFI_NETWORK"
#define WIFI_PASSWORD    "YOUR_WIFI_PASSWORD"

// ---------- Groq (console.groq.com) ----------
#define GROQ_API_KEY     "gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
#define GROQ_STT_MODEL   "whisper-large-v3-turbo"
#define GROQ_LLM_MODEL   "llama-3.1-8b-instant"

// ---------- Gemini (Google AI Studio) — cerebro principal + vision ----------
// 1. Entra en https://aistudio.google.com/apikey
// 2. "Create API Key" -> copia la clave (empieza por "AIza...").
// 3. No la subas a git. Pegala aqui en tu config.h LOCAL.
// Usamos Gemini 2.0 Flash: rapido, multimodal nativo y no alucina como
// los VLM pequenos. En cada turno le enviamos un JPEG fresco de la camara
// + texto -> "ve en tiempo real" sin tocar otro modelo aparte.
#define GEMINI_API_KEY      "AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
#define GEMINI_MODEL        "gemini-2.0-flash"
#define GEMINI_ENABLED      true
// Si true, adjunta un frame de camara a CADA respuesta (aunque el usuario
// no diga "mira"). Asi TARS siempre razona con vision en tiempo real.
#define GEMINI_ALWAYS_SEE   true
// Rafaga multi-frame: en vez de 1 foto, enviamos N frames espaciados
// GEMINI_BURST_INTERVAL_MS ms cada uno. El modelo los ve como "video corto"
// y detecta movimiento, gestos, cambios de escena. Pon N=1 para volver al
// modo foto. 3-5 frames es el punto dulce (buena percepcion de movimiento,
// latencia < 2 s total).
#define GEMINI_BURST_FRAMES        3
#define GEMINI_BURST_INTERVAL_MS   300

// ---------- Telegram Bot ----------
// 1. Telegram -> @BotFather -> /newbot -> copia el TOKEN.
// 2. Manda /start a tu nuevo bot.
// 3. https://api.telegram.org/bot<TOKEN>/getUpdates -> copia chat.id.
#define TELEGRAM_BOT_TOKEN  "1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
#define TELEGRAM_CHAT_ID    "123456789"

// ---------- Memoria a largo plazo (Mem0) ----------
// 1. https://app.mem0.ai -> Settings -> API Keys -> copia la key ("m0-...")
// 2. MEM0_USER_ID es tu nombre/alias. Mem0 separa memorias por user_id.
#define MEM0_API_KEY     "m0-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
#define MEM0_USER_ID     "yo"
#define MEM0_ENABLED     true
#define MEM0_RECALL_LIMIT 5

// ---------- Vision ----------
#define VISION_ENABLED    true
#define GROQ_VISION_MODEL "meta-llama/llama-4-maverick-17b-128e-instruct"
#define VISION_TRIGGERS   "mira,ves,vez,que ves,fijate,observa,describe,mirar,foto,camara"

// ---------- TARS identity ----------
#define TARS_HUMOR_LEVEL 75
#define TARS_SYSTEM_PROMPT \
    "Eres TARS, un robot militar rectangular inspirado en la pelicula Interstellar. " \
    "Tu nivel de humor es del 75 por ciento. Eres directo, sarcastico y brutalmente honesto. " \
    "Hablas siempre en espanol, de forma natural y cercana. " \
    "Tus respuestas son muy cortas (maximo 2 frases), secas y con humor sarcastico militar. " \
    "Nunca rompes el personaje. Nunca uses emojis. Nunca expliques que eres una IA."

// ---------- Audio capture ----------
#define SAMPLE_RATE        16000
#define RECORD_SECONDS     5
#define VAD_THRESHOLD      1500
#define SILENCE_TIMEOUT_MS 1200

// ---------- Behaviour ----------
#define SEND_MESSAGE_TELEGRAM  true
#define HTTP_TIMEOUT_MS        30000

// ---------- Wake word ----------
// Whisper a veces escribe "Lars" o "Tarz" en vez de "tars". Aceptamos varias.
#define WAKE_WORDS         "tars,lars,tarz,tarss,tas"
#define REQUIRE_WAKE_WORD  true
